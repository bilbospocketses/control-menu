@page "/utilities/icon-converter"
@using ControlMenu.Modules.Utilities.Services
@using Microsoft.AspNetCore.Components.Forms
@inject IIconConversionService IconService
@inject IWebHostEnvironment Env

<PageTitle>Icon Converter</PageTitle>

<h1><i class="bi bi-file-earmark-image"></i> Icon Converter</h1>
<p class="page-subtitle">Convert an image file (PNG, JPG, etc.) to an ICO file with multiple sizes.</p>

<div class="converter-panel">
    <div class="form-group">
        <label class="form-label">Source Image Path</label>
        <input type="text" class="form-control" style="max-width:500px;"
               placeholder="C:\path\to\image.png"
               @bind="_sourcePath" />
        <div class="form-hint">Full path to the image on this machine. The ICO will be saved next to it.</div>
    </div>

    <div class="form-group" style="color:var(--text-muted); font-size:0.85rem;">
        <em>— or upload —</em>
    </div>

    <div class="form-group">
        <label class="form-label">Upload Image</label>
        <InputFile OnChange="OnFileSelected" accept=".png,.jpg,.jpeg,.bmp,.gif" class="form-input" />
        @if (_selectedFile is not null)
        {
            <span class="file-info">@_selectedFile.Name (@FormatSize(_selectedFile.Size))</span>
        }
    </div>

    <div class="form-group">
        <label class="form-label">Icon Sizes</label>
        <div class="size-options">
            @foreach (var size in _availableSizes)
            {
                <label class="size-checkbox">
                    <input type="checkbox" checked="@_selectedSizes.Contains(size)" @onchange="e => ToggleSize(size, (bool)e.Value!)" />
                    @(size)px
                </label>
            }
        </div>
    </div>

    <div class="form-group">
        <label class="form-label">Output Filename</label>
        <input type="text" @bind="_outputName" class="form-input" placeholder="icon.ico" />
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="error-panel">
            <i class="bi bi-exclamation-triangle"></i> @_error
        </div>
    }

    @if (_converting)
    {
        <div class="status-info">
            <i class="bi bi-arrow-repeat spin"></i> Converting...
        </div>
    }

    <button class="btn btn-primary btn-lg" @onclick="Convert"
            disabled="@((_selectedFile is null && string.IsNullOrWhiteSpace(_sourcePath)) || _converting || _selectedSizes.Count == 0)">
        <i class="bi bi-arrow-right-circle"></i> Convert to ICO
    </button>

    @if (_downloadReady)
    {
        <div class="download-panel">
            <i class="bi bi-check-circle-fill"></i>
            <span>Conversion complete!</span>
            @if (_savedPath is not null)
            {
                <span class="file-info" style="display:block; margin-top:0.25rem;">
                    Saved to: <code>@_savedPath</code>
                </span>
            }
            @if (_downloadUrl is not null)
            {
                <a href="@_downloadUrl" download="@_outputName" class="btn-pill btn-pill-success">
                    <i class="bi bi-download"></i> Download @_outputName
                </a>
            }
        </div>
    }
</div>

@code {
    private IBrowserFile? _selectedFile;
    private string _sourcePath = "";
    private readonly int[] _availableSizes = [16, 32, 48, 64, 128, 256];
    private HashSet<int> _selectedSizes = [64, 128, 256];
    private string _outputName = "icon.ico";
    private bool _converting;
    private bool _downloadReady;
    private string? _downloadUrl;
    private string? _savedPath;
    private string? _error;

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _sourcePath = "";
        _downloadReady = false;
        _error = null;

        var baseName = Path.GetFileNameWithoutExtension(e.File.Name);
        _outputName = $"{baseName}.ico";
    }

    private void ToggleSize(int size, bool selected)
    {
        if (selected) _selectedSizes.Add(size);
        else _selectedSizes.Remove(size);
    }

    private async Task Convert()
    {
        if (_selectedFile is null && string.IsNullOrWhiteSpace(_sourcePath)) return;
        if (_selectedSizes.Count == 0) return;

        _converting = true;
        _downloadReady = false;
        _downloadUrl = null;
        _savedPath = null;
        _error = null;

        try
        {
            var sizes = _selectedSizes.OrderBy(s => s).ToArray();
            string actualSourcePath;

            if (!string.IsNullOrWhiteSpace(_sourcePath))
            {
                // Direct path mode — source is on disk, save ICO alongside it
                actualSourcePath = _sourcePath.Trim();
                if (!File.Exists(actualSourcePath))
                {
                    _error = $"File not found: {actualSourcePath}";
                    return;
                }

                var sourceDir = Path.GetDirectoryName(actualSourcePath)!;
                var targetPath = Path.Combine(sourceDir, _outputName);
                await IconService.ConvertToIcoAsync(actualSourcePath, targetPath, sizes);
                _savedPath = targetPath;

                // Also create a web-downloadable copy
                var tempDir = Path.Combine(Env.WebRootPath, "temp");
                Directory.CreateDirectory(tempDir);
                var webCopy = Path.Combine(tempDir, $"{Guid.NewGuid():N}.ico");
                File.Copy(targetPath, webCopy);
                _downloadUrl = $"/temp/{Path.GetFileName(webCopy)}";

                _ = Task.Delay(TimeSpan.FromMinutes(5)).ContinueWith(_ =>
                {
                    try { if (File.Exists(webCopy)) File.Delete(webCopy); } catch { }
                });
            }
            else if (_selectedFile is not null)
            {
                // Upload mode — save to temp, convert, offer download only
                var tempDir = Path.Combine(Env.WebRootPath, "temp");
                Directory.CreateDirectory(tempDir);

                actualSourcePath = Path.Combine(tempDir, $"{Guid.NewGuid():N}{Path.GetExtension(_selectedFile.Name)}");
                var targetPath = Path.Combine(tempDir, $"{Guid.NewGuid():N}.ico");

                await using (var stream = _selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024))
                await using (var fileStream = new FileStream(actualSourcePath, FileMode.Create))
                {
                    await stream.CopyToAsync(fileStream);
                }

                await IconService.ConvertToIcoAsync(actualSourcePath, targetPath, sizes);
                _downloadUrl = $"/temp/{Path.GetFileName(targetPath)}";

                File.Delete(actualSourcePath);

                _ = Task.Delay(TimeSpan.FromMinutes(5)).ContinueWith(_ =>
                {
                    try { if (File.Exists(targetPath)) File.Delete(targetPath); } catch { }
                });
            }

            _downloadReady = true;
        }
        catch (Exception ex)
        {
            _error = $"Conversion failed: {ex.Message}";
        }
        finally
        {
            _converting = false;
        }
    }

    private static string FormatSize(long bytes) => ControlMenu.Services.FormatHelper.FormatSize(bytes);
}
