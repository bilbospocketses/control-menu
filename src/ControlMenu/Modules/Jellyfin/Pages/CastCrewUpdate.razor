@page "/jellyfin/cast-crew"
@using ControlMenu.Data.Entities
@using ControlMenu.Data.Enums
@using ControlMenu.Services
@using ControlMenu.Modules.Jellyfin.Services
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Logging
@implements IDisposable

<PageTitle>Jellyfin — Cast & Crew Update</PageTitle>

<h1><i class="bi bi-people"></i> Cast & Crew Image Update</h1>
<p class="page-subtitle">Updates images for all cast members, directors, and producers in Jellyfin media libraries. This process typically takes several hours to complete.</p>

@if (_activeJob is not null)
{
    <div class="job-panel">
        <div class="job-header">
            <span class="job-status-badge @_activeJob.Status.ToString().ToLower()">
                @_activeJob.Status
            </span>
            @if (_activeJob.StartedAt.HasValue)
            {
                <span class="job-time">Started: @_activeJob.StartedAt.Value.ToLocalTime().ToString("g")</span>
            }
        </div>

        @if (_activeJob.Status == JobStatus.Running || _activeJob.Status == JobStatus.Queued)
        {
            <div class="progress-bar-container">
                <div class="progress-bar-fill" style="width: @(_activeJob.Progress ?? 0)%"></div>
            </div>
            <div class="progress-info">
                <span>@(_activeJob.Progress ?? 0)%</span>
                <span>@(_activeJob.ProgressMessage ?? "Waiting...")</span>
            </div>
            <button class="btn btn-danger" @onclick="CancelJob">
                <i class="bi bi-stop-circle"></i> Cancel
            </button>
        }
        else if (_activeJob.Status == JobStatus.Completed)
        {
            <div class="job-complete">
                <i class="bi bi-check-circle-fill"></i>
                <p>Update completed at @_activeJob.CompletedAt?.ToLocalTime().ToString("g").</p>
            </div>
        }
        else if (_activeJob.Status == JobStatus.Failed)
        {
            <div class="job-failed">
                <i class="bi bi-x-circle-fill"></i>
                <p>@_activeJob.ErrorMessage</p>
            </div>
        }
    </div>
}
else
{
    <div class="start-panel">
        <div class="info-box">
            <i class="bi bi-info-circle"></i>
            <div>
                <p><strong>What this does:</strong> Calls the Jellyfin API to find all people without images and triggers an image refresh for each one.</p>
                <p><strong>Duration:</strong> Typically about 2 hours for large libraries.</p>
                <p><strong>Runs in background:</strong> You can close this page. A notification email is sent when finished.</p>
            </div>
        </div>
        <button class="btn btn-primary btn-lg" @onclick="StartJob" disabled="@_starting">
            <i class="bi bi-play-circle"></i> Start Update
        </button>
    </div>
}

@if (_recentJobs.Count > 0)
{
    <h2>Job History</h2>
    <table class="data-table">
        <thead>
            <tr>
                <th>Status</th>
                <th>Started</th>
                <th>Completed</th>
                <th>Progress</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var job in _recentJobs)
            {
                <tr>
                    <td><span class="job-status-badge @job.Status.ToString().ToLower()">@job.Status</span></td>
                    <td>@(job.StartedAt?.ToLocalTime().ToString("g") ?? "—")</td>
                    <td>@(job.CompletedAt?.ToLocalTime().ToString("g") ?? "—")</td>
                    <td>@(job.Progress ?? 0)%</td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_recentLogs.Count > 0)
{
    <h2>Recent Logs</h2>
    <table class="data-table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Status</th>
                <th>Summary</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in _recentLogs)
            {
                <tr>
                    <td>@log.Timestamp.ToLocalTime().ToString("g")</td>
                    <td>
                        @if (log.Status == OperationLogStatus.InProgress)
                        {
                            <span class="status-badge status-running">Running</span>
                        }
                        else if (log.Status == OperationLogStatus.Success)
                        {
                            <span class="status-badge status-ok">Success</span>
                        }
                        else
                        {
                            <span class="status-badge status-error">Failed</span>
                        }
                    </td>
                    <td style="font-size:0.85rem;color:var(--text-secondary);">@log.Summary</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Inject] private IBackgroundJobService JobService { get; set; } = default!;
    [Inject] private IServiceScopeFactory ScopeFactory { get; set; } = default!;
    [Inject] private ILogger<CastCrewUpdate> Logger { get; set; } = default!;

    private Job? _activeJob;
    private List<Job> _recentJobs = [];
    private List<OperationLogEntry> _recentLogs = [];
    private bool _starting;
    private bool _disposed;
    private Timer? _pollTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadJobs();

        _pollTimer = new Timer(async _ =>
        {
            if (_disposed) return;
            try
            {
                await InvokeAsync(async () =>
                {
                    if (_disposed) return;
                    await LoadJobs();
                    StateHasChanged();
                });
            }
            catch (ObjectDisposedException) { }
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private async Task LoadJobs()
    {
        var allJobs = await JobService.GetJobsByModuleAsync("jellyfin");
        var castCrewJobs = allJobs.Where(j => j.JobType == "cast-crew-update").ToList();

        _activeJob = castCrewJobs.FirstOrDefault(j =>
            j.Status == JobStatus.Running || j.Status == JobStatus.Queued);

        _recentJobs = castCrewJobs
            .Where(j => j.Status == JobStatus.Completed || j.Status == JobStatus.Failed || j.Status == JobStatus.Cancelled)
            .Take(10)
            .ToList();

        _recentLogs = OperationLogger.GetRecentLogs(10)
            .Where(l => l.Operation == "cast-crew-update")
            .ToList();
    }

    private async Task StartJob()
    {
        _starting = true;
        var job = await JobService.CreateJobAsync("jellyfin", "cast-crew-update");
        _activeJob = job;
        var jobId = job.Id;

        // Launch worker with its own DI scope — no component-level CancellationToken.
        // The worker checks CancellationRequested in the DB each batch, so it survives
        // circuit disconnects and page navigations.
        _ = Task.Run(async () =>
        {
            try
            {
                Logger.LogInformation("Cast & Crew worker starting for job {JobId}", jobId);
                using var scope = ScopeFactory.CreateScope();
                var config = scope.ServiceProvider.GetRequiredService<IConfigurationService>();
                var tzSetting = await config.GetSettingAsync("app-timezone");
                var utcOffset = OperationLogger.ParseTimezoneOffset(tzSetting);
                using var opLog = OperationLogger.Create("cast-crew-update", utcOffset);
                var jellyfinService = scope.ServiceProvider.GetRequiredService<IJellyfinService>();
                var jobService = scope.ServiceProvider.GetRequiredService<IBackgroundJobService>();
                var emailService = scope.ServiceProvider.GetRequiredService<IEmailService>();

                await jobService.StartJobAsync(jobId, Environment.ProcessId);
                var worker = new Workers.CastCrewUpdateWorker(jellyfinService, jobService, emailService, config, opLog);
                await worker.ExecuteAsync(jobId, CancellationToken.None);
                Logger.LogInformation("Cast & Crew worker finished for job {JobId}", jobId);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Cast & Crew worker failed for job {JobId}", jobId);
            }
        });

        _starting = false;
    }

    private async Task CancelJob()
    {
        if (_activeJob is null) return;
        await JobService.RequestCancellationAsync(_activeJob.Id);
    }

    public void Dispose()
    {
        _disposed = true;
        _pollTimer?.Dispose();
    }
}
