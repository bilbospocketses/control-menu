@using ControlMenu.Modules.AndroidDevices.Services
@using ControlMenu.Services
@inject IAdbService AdbService
@inject INetworkDiscoveryService NetworkDiscovery

<div class="usb-wizard">
    <div class="wizard-header">
        <h4>Enable Wireless ADB</h4>
        <span class="wizard-step">Step @_step of 3</span>
    </div>

    @if (_step == 1)
    {
        <div class="wizard-body">
            <p><i class="bi bi-usb-plug"></i> <strong>Connect your phone</strong> to this computer with a USB cable.</p>
            <p class="wizard-hint">Make sure USB Debugging is enabled in Developer Options on the phone.</p>

            @if (_error is not null)
            {
                <div class="wizard-error">
                    <i class="bi bi-exclamation-triangle"></i> @_error
                </div>
            }

            <div class="wizard-actions">
                <button class="btn btn-secondary btn-sm" @onclick="Cancel">Cancel</button>
                <button class="btn btn-primary btn-sm" @onclick="CheckUsbDevice" disabled="@_busy">
                    @if (_busy) { <span class="spinner"></span> } I've Connected
                </button>
            </div>
        </div>
    }
    else if (_step == 2)
    {
        <div class="wizard-body">
            <p><i class="bi bi-wifi"></i> <strong>Switching to wireless mode...</strong></p>
            <p class="wizard-hint">Running <code>adb tcpip @Port</code> on the device.</p>

            @if (_busy)
            {
                <div class="wizard-status"><span class="spinner"></span> Please wait...</div>
            }
            else if (_error is not null)
            {
                <div class="wizard-error">
                    <i class="bi bi-exclamation-triangle"></i> @_error
                </div>
                <div class="wizard-actions">
                    <button class="btn btn-secondary btn-sm" @onclick="Cancel">Cancel</button>
                    <button class="btn btn-primary btn-sm" @onclick="EnableTcpMode">Retry</button>
                </div>
            }
            else
            {
                <div class="wizard-success">
                    <i class="bi bi-check-circle"></i> Wireless ADB enabled on port @Port.
                </div>
            }
        </div>
    }
    else if (_step == 3)
    {
        <div class="wizard-body">
            <p><i class="bi bi-plug"></i> <strong>Disconnect the USB cable</strong> from your phone now.</p>

            @if (_showManualIp)
            {
                <p class="wizard-hint">
                    Could not find the device via ARP lookup. This often happens when the phone uses
                    a randomized WiFi MAC address. Enter the phone's IP manually
                    (check WiFi settings on the phone).
                </p>
                <div class="manual-ip-row">
                    <input class="form-control form-control-sm" @bind="_manualIp"
                           placeholder="192.168.86.xxx" style="max-width:200px;" />
                    <button class="btn btn-primary btn-sm" @onclick="ConnectWithManualIp" disabled="@(_busy || string.IsNullOrWhiteSpace(_manualIp))">
                        @if (_busy) { <span class="spinner"></span> } Connect
                    </button>
                </div>
            }

            @if (_error is not null)
            {
                <div class="wizard-error">
                    <i class="bi bi-exclamation-triangle"></i> @_error
                </div>
            }
            else if (_success)
            {
                <div class="wizard-success">
                    <i class="bi bi-check-circle"></i> Connected wirelessly to @_resolvedIp:@Port. You're all set.
                </div>
            }

            <div class="wizard-actions">
                @if (_success)
                {
                    <button class="btn btn-primary btn-sm" @onclick="Finish">Done</button>
                }
                else if (!_showManualIp)
                {
                    <button class="btn btn-secondary btn-sm" @onclick="Cancel">Cancel</button>
                    <button class="btn btn-primary btn-sm" @onclick="ConnectWirelessly" disabled="@_busy">
                        @if (_busy) { <span class="spinner"></span> } Connect Wirelessly
                    </button>
                }
                else
                {
                    <button class="btn btn-secondary btn-sm" @onclick="Cancel">Cancel</button>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Port { get; set; } = 5555;
    [Parameter] public string? Ip { get; set; }
    [Parameter] public string? MacAddress { get; set; }
    [Parameter] public EventCallback<bool> OnComplete { get; set; }

    private int _step = 1;
    private bool _busy;
    private bool _success;
    private bool _showManualIp;
    private string? _error;
    private string _manualIp = "";
    private string? _resolvedIp;

    private async Task CheckUsbDevice()
    {
        _busy = true;
        _error = null;
        StateHasChanged();

        var usbDevices = await AdbService.GetUsbDevicesAsync();
        if (usbDevices.Count == 0)
        {
            _error = "No USB device detected. Check the cable and ensure USB Debugging is enabled, then try again.";
            _busy = false;
            return;
        }

        _busy = false;
        _step = 2;
        StateHasChanged();
        await EnableTcpMode();
    }

    private async Task EnableTcpMode()
    {
        _busy = true;
        _error = null;
        StateHasChanged();

        try
        {
            await AdbService.ResetTcpPortAsync(Port);
            _busy = false;
            // Brief pause for the device to switch modes
            StateHasChanged();
            await Task.Delay(1500);
            _step = 3;
        }
        catch (Exception ex)
        {
            _error = $"Failed to enable wireless mode: {ex.Message}";
            _busy = false;
        }
    }

    private async Task ConnectWirelessly()
    {
        _busy = true;
        _error = null;
        _showManualIp = false;
        StateHasChanged();

        // If we already have an IP (from the device record), try it directly
        if (!string.IsNullOrEmpty(Ip))
        {
            if (await TryConnect(Ip))
                return;
        }

        // Try ARP resolution from MAC
        if (!string.IsNullOrEmpty(MacAddress))
        {
            var resolved = await NetworkDiscovery.ResolveIpFromMacAsync(MacAddress);
            if (resolved is not null && await TryConnect(resolved))
                return;
        }

        // ARP failed — show manual IP input
        _busy = false;
        _showManualIp = true;
        _error = null;
    }

    private async Task ConnectWithManualIp()
    {
        _busy = true;
        _error = null;
        StateHasChanged();

        if (await TryConnect(_manualIp.Trim()))
            return;

        _busy = false;
        _error = $"Failed to connect to {_manualIp.Trim()}:{Port}. Check the IP and try again.";
    }

    private async Task<bool> TryConnect(string ip)
    {
        var connected = await AdbService.ConnectAsync(ip, Port);
        if (connected)
        {
            _resolvedIp = ip;
            _success = true;
            _busy = false;
            return true;
        }
        return false;
    }

    private async Task Finish()
    {
        await OnComplete.InvokeAsync(true);
    }

    private async Task Cancel()
    {
        await OnComplete.InvokeAsync(false);
    }
}
