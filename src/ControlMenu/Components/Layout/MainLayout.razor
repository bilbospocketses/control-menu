@inherits LayoutComponentBase
@inject NavigationManager Nav
@implements IDisposable

<div class="app-layout">
    <Sidebar />

    <div class="app-main">
        <TopBar PageTitle="@_pageTitle" />

        <main class="app-content">
            @Body
        </main>
    </div>
</div>

@code {
    private string _pageTitle = "Home";

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        UpdateTitle(Nav.Uri);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateTitle(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private void UpdateTitle(string uri)
    {
        var path = new Uri(uri).AbsolutePath.Trim('/');
        _pageTitle = path switch
        {
            "" => "Home",
            "settings" or "settings/general" => "Settings",
            "settings/devices" => "Settings — Devices",
            "settings/jellyfin" => "Settings — Jellyfin",
            "settings/dependencies" => "Settings — Dependencies",
            "settings/cameras" => "Settings — Cameras",
            "setup" => "Setup Wizard",
            _ when path.StartsWith("android/googletv") => "Google TV Dashboard",
            _ when path.StartsWith("android/phone") || path.StartsWith("android/pixel") => "Android Phone",
            _ when path.StartsWith("android") => "Android Devices",
            _ when path.StartsWith("jellyfin/db-update") => "DB Date Update",
            _ when path.StartsWith("jellyfin/cast-crew") => "Cast & Crew Update",
            _ when path.StartsWith("utilities/icon") => "Icon Converter",
            _ when path.StartsWith("utilities/unblock") => "File Unblocker",
            _ when path.StartsWith("cameras/") => "Camera",
            _ => path.Split('/').Last().Replace("-", " ")
        };
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
