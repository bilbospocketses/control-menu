@using ControlMenu.Data.Entities
@using ControlMenu.Data.Enums
@inject IDependencyManagerService DepManager
@inject NavigationManager Nav

<div class="settings-section">
    <h2>Dependencies</h2>
    <p>External tools required by modules. Version checks run automatically on a daily schedule.</p>

    <div class="toolbar">
        <button class="btn btn-secondary" @onclick="CheckAll" disabled="@_checkingAll">
            <i class="bi bi-arrow-repeat"></i> @(_checkingAll ? "Checking..." : "Check All")
        </button>
        @if (_updatableCount > 0)
        {
            <button class="btn btn-primary" @onclick="UpdateAll" disabled="@_updatingAll">
                <i class="bi bi-download"></i>
                @if (_updatingAll)
                {
                    @:Updating @_updateProgress of @_updatableCount...
                }
                else
                {
                    @:Update All (@_updatableCount)
                }
            </button>
        }
    </div>

    @if (_dependencies.Count == 0)
    {
        <p style="color: var(--text-muted);">No dependencies registered. Install modules that declare external tool requirements.</p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Module</th>
                    <th>Installed</th>
                    <th>Latest</th>
                    <th>Status</th>
                    <th>Install Path</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dep in _sortedDependencies)
                {
                    var isConfigurable = DepManager.IsConfigurable(dep.Name, dep.ModuleId);
                    <tr>
                        <td><strong>@dep.Name</strong></td>
                        <td>@dep.ModuleId</td>
                        <td><code>@(dep.InstalledVersion ?? "—")</code></td>
                        <td><code>@(dep.LatestKnownVersion ?? "—")</code></td>
                        <td><span class="status-badge @GetStatusClass(dep.Status)">@FormatStatus(dep.Status)</span></td>
                        <td>
                            @if (isConfigurable)
                            {
                                <div style="display:flex; gap:0.4rem; align-items:center;">
                                    <input class="form-control" style="min-width:200px; font-size:0.85rem;"
                                           value="@(_installPaths.GetValueOrDefault(dep.Name, ""))"
                                           @onchange="e => OnPathChanged(dep.Name, dep.ModuleId, e)" />
                                    <button class="btn btn-secondary btn-sm" title="Reset to default"
                                            @onclick="() => ResetPath(dep.Name, dep.ModuleId)">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                    </button>
                                </div>
                            }
                            else
                            {
                                <span style="color:var(--text-muted); font-size:0.85rem;">External</span>
                            }
                        </td>
                        <td class="actions">
                            @if (dep.Status == DependencyStatus.UpdateAvailable && _hasInstallPath.Contains(dep.Name))
                            {
                                <button class="btn btn-primary btn-sm" @onclick="() => StartUpdate(dep)"
                                        disabled="@(_updatingId == dep.Id)">
                                    @(_updatingId == dep.Id ? "Updating..." : "Update")
                                </button>
                            }
                            else if (dep.InstalledVersion is null && DepManager.CanAutoInstall(dep.Name, dep.ModuleId))
                            {
                                <button class="btn btn-primary btn-sm" @onclick="() => StartUpdate(dep)"
                                        disabled="@(_updatingId == dep.Id)">
                                    @(_updatingId == dep.Id ? "Installing..." : "Install")
                                </button>
                            }
                            <button class="btn btn-secondary btn-sm" @onclick="() => CheckOne(dep.Id)"
                                    disabled="@(_checkingId == dep.Id)">
                                @(_checkingId == dep.Id ? "..." : "Check")
                            </button>
                            @if (dep.ProjectHomeUrl is not null)
                            {
                                <a class="btn btn-secondary btn-sm" href="@dep.ProjectHomeUrl"
                                   target="_blank" rel="noopener">
                                    <i class="bi bi-box-arrow-up-right"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (_showUpdateDialog)
    {
        <div class="modal-overlay">
            <div class="modal-dialog">
                @if (_resolvedAsset is null)
                {
                    <p><i class="bi bi-hourglass-split"></i> Resolving download...</p>
                }
                else
                {
                    <h3>Download &amp; Install</h3>
                    <p>Download <code>@_resolvedAsset.FileName</code> (@FormatSize(_resolvedAsset.SizeBytes))?</p>
                    <div class="modal-actions">
                        <button class="btn btn-primary" @onclick="ConfirmDownload">Download</button>
                        <button class="btn btn-secondary" @onclick="CancelUpdate">Cancel</button>
                    </div>
                }
            </div>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_messageIsError ? "alert-danger" : "alert-success")" style="margin-top:1rem;">
        @_message
    </div>
}

@code {
    private List<Dependency> _dependencies = [];
    private List<Dependency> _sortedDependencies = [];
    private HashSet<string> _hasInstallPath = [];
    private Dictionary<string, string> _installPaths = new();
    private bool _checkingAll;
    private Guid? _checkingId;
    private Guid? _updatingId;
    private string? _message;
    private bool _messageIsError;
    private bool _showUpdateDialog;
    private AssetMatch? _resolvedAsset;
    private Guid _updateTargetId;
    private int _updatableCount;
    private bool _updatingAll;
    private int _updateProgress;

    [Inject] private ModuleDiscoveryService ModuleDiscovery { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadDependencies();
    }

    private async Task LoadDependencies()
    {
        _dependencies = (await DepManager.GetAllDependenciesAsync()).ToList();
        _hasInstallPath = ModuleDiscovery.Modules
            .SelectMany(m => m.Dependencies)
            .Where(d => !string.IsNullOrEmpty(d.InstallPath))
            .Select(d => d.Name)
            .ToHashSet();
        _updatableCount = _dependencies.Count(d =>
            d.Status == DependencyStatus.UpdateAvailable && _hasInstallPath.Contains(d.Name));

        // Sort: external (docker, ws-scrcpy-web) at top, managed at bottom
        _sortedDependencies = _dependencies
            .OrderBy(d => DepManager.IsConfigurable(d.Name, d.ModuleId) ? 1 : 0)
            .ThenBy(d => d.Name)
            .ToList();

        // Load install paths for configurable deps
        _installPaths.Clear();
        foreach (var dep in _dependencies.Where(d => DepManager.IsConfigurable(d.Name, d.ModuleId)))
        {
            var path = await DepManager.GetInstallPathAsync(dep.Name, dep.ModuleId);
            _installPaths[dep.Name] = path ?? "";
        }
    }

    private async Task CheckAll()
    {
        _checkingAll = true;
        _message = null;
        StateHasChanged();

        var results = await DepManager.CheckAllAsync();
        var updates = results.Count(r => r.Status == DependencyStatus.UpdateAvailable);

        _checkingAll = false;
        ShowSaveMessage(updates > 0
            ? $"{updates} update(s) available"
            : "All dependencies up to date");

        await LoadDependencies();
    }

    private async Task CheckOne(Guid id)
    {
        _checkingId = id;
        StateHasChanged();

        await DepManager.CheckDependencyAsync(id);
        _checkingId = null;

        await LoadDependencies();
    }

    private async Task StartUpdate(Dependency dep)
    {
        _updateTargetId = dep.Id;
        _showUpdateDialog = true;
        _resolvedAsset = null;
        StateHasChanged();

        _resolvedAsset = await DepManager.ResolveDownloadAssetAsync(dep.Id);

        if (_resolvedAsset is null)
        {
            _showUpdateDialog = false;
            _message = $"Could not resolve download for {dep.Name}";
            _messageIsError = true;
        }

        StateHasChanged();
    }

    private async Task ConfirmDownload()
    {
        _showUpdateDialog = false;
        _updatingId = _updateTargetId;
        StateHasChanged();

        var result = await DepManager.DownloadAndInstallAsync(_updateTargetId, _resolvedAsset!);

        _updatingId = null;
        ShowSaveMessage(
            result.Success ? $"Updated to version {result.NewVersion}" : $"Update failed: {result.ErrorMessage}",
            !result.Success);

        await LoadDependencies();
    }

    private void CancelUpdate()
    {
        _showUpdateDialog = false;
        _resolvedAsset = null;
    }

    private async Task UpdateAll()
    {
        _updatingAll = true;
        _updateProgress = 0;
        _message = null;
        StateHasChanged();

        var toUpdate = _dependencies
            .Where(d => d.Status == DependencyStatus.UpdateAvailable && _hasInstallPath.Contains(d.Name))
            .ToList();

        int succeeded = 0;
        int failed = 0;

        foreach (var dep in toUpdate)
        {
            _updateProgress++;
            StateHasChanged();

            var asset = await DepManager.ResolveDownloadAssetAsync(dep.Id);
            if (asset is null)
            {
                failed++;
                continue;
            }

            var result = await DepManager.DownloadAndInstallAsync(dep.Id, asset);
            if (result.Success)
                succeeded++;
            else
                failed++;
        }

        _updatingAll = false;
        await LoadDependencies();

        ShowSaveMessage(
            failed == 0
                ? $"Updated {succeeded} dependenc{(succeeded == 1 ? "y" : "ies")} successfully"
                : $"Updated {succeeded}, failed {failed}",
            failed > 0);
    }

    private async Task OnPathChanged(string name, string moduleId, ChangeEventArgs e)
    {
        var newPath = e.Value?.ToString()?.Trim() ?? "";
        _installPaths[name] = newPath;
        if (!string.IsNullOrEmpty(newPath))
            await DepManager.SetInstallPathAsync(name, newPath);
        ShowSaveMessage($"{name} install path saved.");
    }

    private async Task ResetPath(string name, string moduleId)
    {
        await DepManager.SetInstallPathAsync(name, "");
        var defaultPath = DepManager.GetInstallPath(name, moduleId) ?? "";
        _installPaths[name] = defaultPath;
        ShowSaveMessage($"{name} path reset to default.");
    }

    private void ShowSaveMessage(string msg, bool isError = false)
    {
        _message = msg;
        _messageIsError = isError;
        _ = Task.Delay(isError ? 10000 : 5000).ContinueWith(_ => InvokeAsync(() =>
        {
            _message = null;
            StateHasChanged();
        }));
    }

    private static string GetStatusClass(DependencyStatus status) => status switch
    {
        DependencyStatus.UpToDate => "status-ok",
        DependencyStatus.UpdateAvailable => "status-warning",
        DependencyStatus.UrlInvalid => "status-error",
        DependencyStatus.CheckFailed => "status-error",
        _ => ""
    };

    private static string FormatStatus(DependencyStatus status) => status switch
    {
        DependencyStatus.UpToDate => "Up to Date",
        DependencyStatus.UpdateAvailable => "Update Available",
        DependencyStatus.UrlInvalid => "URL Invalid",
        DependencyStatus.CheckFailed => "Check Failed",
        _ => status.ToString()
    };

    private static string FormatSize(long bytes) => Services.FormatHelper.FormatSize(bytes);
}
