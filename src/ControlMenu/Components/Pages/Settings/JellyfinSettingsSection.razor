@using ControlMenu.Services
@using ControlMenu.Modules.Jellyfin.Services

<div class="settings-section">
    <h2>Docker Compose</h2>
    <p>Point Control Menu to your Jellyfin docker-compose.yml to auto-detect container name and database path.</p>

    <div class="form-row" style="display:flex;gap:8px;align-items:center;margin-bottom:1rem;">
        <label style="white-space:nowrap;">Compose File Path</label>
        <input type="text" class="form-control" @bind="_composePath" placeholder="e.g., D:\DockerData\jellyfin\docker-compose.yml" style="flex:1;" />
        <button class="btn btn-primary" @onclick="SaveAndParse" disabled="@_parsing">
            <i class="bi bi-arrow-repeat"></i> @(_parsing ? "Parsing..." : "Save & Parse")
        </button>
    </div>

    @if (_parseResult is not null)
    {
        @if (_parseResult.ErrorMessage is not null)
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle"></i> @_parseResult.ErrorMessage
            </div>
        }
        else
        {
            <table class="data-table" style="max-width:600px;">
                <tr>
                    <td><strong>Container Name</strong></td>
                    <td><code>@(_parseResult.ContainerName ?? "—")</code></td>
                </tr>
                <tr>
                    <td><strong>Database Path</strong></td>
                    <td><code>@(_parseResult.DbPath ?? "—")</code></td>
                </tr>
                <tr>
                    <td><strong>Backup Directory</strong></td>
                    <td><code>@OperationLogger.GetBackupDirectory()</code></td>
                </tr>
            </table>
        }
    }
</div>

<div class="settings-section" style="margin-top:2rem;">
    <h2>Jellyfin API</h2>
    <div class="form-group">
        <label>Base URL</label>
        <input class="form-control" style="max-width:300px;" value="@_baseUrl"
               placeholder="http://127.0.0.1:8096" @onchange="SaveBaseUrl" />
    </div>
    <div class="form-group">
        <label>API Key</label>
        <input type="password" class="form-control" style="max-width:300px;" value="@_apiKey"
               @onchange="SaveApiKey" />
    </div>
    <div class="form-group">
        <label>User ID</label>
        <input class="form-control" style="max-width:300px;" value="@_userId"
               @onchange="SaveUserId" />
        <div class="form-hint">Jellyfin user ID for API calls (used by Cast & Crew updates).</div>
    </div>
</div>

<div class="settings-section" style="margin-top:2rem;">
    <h2>Backup &amp; Retention</h2>
    <div style="display:flex;gap:8px;align-items:center;">
        <label>Keep backups for</label>
        <input type="number" class="form-control" @bind="_retentionDays" min="1" max="365" style="width:80px;" />
        <span>days</span>
        <button class="btn btn-secondary" @onclick="SaveRetention" style="margin-left:8px;">Save</button>
    </div>
</div>

<div class="settings-section" style="margin-top:2rem;">
    <h2>Cast &amp; Crew Notifications</h2>
    <div class="form-group">
        <label>Notification Email</label>
        <input type="email" class="form-control" style="max-width:300px;" value="@_castCrewEmail"
               placeholder="Uses default from General if blank"
               @onchange="SaveCastCrewEmail" />
        <div class="form-hint">Receives completion alerts for Cast & Crew updates. Leave blank to use the default notification email from General settings.</div>
    </div>
</div>

<div class="settings-section" style="margin-top:2rem;">
    <h2>Managed Directories</h2>
    <table class="data-table" style="max-width:600px;">
        <tr>
            <td><strong>Backups</strong></td>
            <td><code>@OperationLogger.GetBackupDirectory()</code></td>
            <td>@_backupCount files, @FormatSize(_backupSize)</td>
        </tr>
        <tr>
            <td><strong>Logs</strong></td>
            <td><code>@OperationLogger.GetLogDirectory()</code></td>
            <td>@_logCount files</td>
        </tr>
    </table>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_messageIsError ? "alert-danger" : "alert-success")" style="margin-top:1rem;">
        @_message
    </div>
}

@code {
    [Inject] private IConfigurationService Config { get; set; } = default!;
    [Inject] private IJellyfinService JellyfinService { get; set; } = default!;

    private string _composePath = "";
    private string _baseUrl = "";
    private string _apiKey = "";
    private string _userId = "";
    private string _castCrewEmail = "";
    private int _retentionDays = 5;
    private bool _parsing;
    private ComposeParseResult? _parseResult;
    private string? _message;
    private bool _messageIsError;
    private int _backupCount;
    private long _backupSize;
    private int _logCount;

    protected override async Task OnInitializedAsync()
    {
        _composePath = await Config.GetSettingAsync("jellyfin-compose-path") ?? "";
        _baseUrl = await Config.GetSettingAsync("jellyfin-base-url") ?? "http://127.0.0.1:8096";
        _apiKey = await Config.GetSecretAsync("jellyfin-api-key") ?? "";
        _userId = await Config.GetSettingAsync("jellyfin-user-id") ?? "";
        _castCrewEmail = await Config.GetSettingAsync("jellyfin-castcrew-notify-email") ?? "";
        var retStr = await Config.GetSettingAsync("jellyfin-backup-retention-days");
        _retentionDays = int.TryParse(retStr, out var d) ? d : 5;

        RefreshDirectoryStats();

        if (!string.IsNullOrEmpty(_composePath))
        {
            _parseResult = await JellyfinService.ParseComposeFileAsync();
        }
    }

    private async Task SaveAndParse()
    {
        _parsing = true;
        _message = null;
        StateHasChanged();

        await Config.SetSettingAsync("jellyfin-compose-path", _composePath);
        _parseResult = await JellyfinService.ParseComposeFileAsync();

        _message = _parseResult.ErrorMessage is null
            ? "Compose file parsed. Container name and database path configured."
            : _parseResult.ErrorMessage;
        _messageIsError = _parseResult.ErrorMessage is not null;
        _parsing = false;
    }

    private async Task SaveBaseUrl(ChangeEventArgs e)
    {
        _baseUrl = e.Value?.ToString() ?? "";
        await Config.SetSettingAsync("jellyfin-base-url", _baseUrl);
        ShowMessage("Saved.", false);
    }

    private async Task SaveApiKey(ChangeEventArgs e)
    {
        _apiKey = e.Value?.ToString() ?? "";
        if (!string.IsNullOrEmpty(_apiKey))
        {
            await Config.SetSecretAsync("jellyfin-api-key", _apiKey);
            ShowMessage("Saved.", false);
        }
        else
        {
            await Config.DeleteSettingAsync("jellyfin-api-key");
            ShowMessage("API key cleared.", false);
        }
    }

    private async Task SaveUserId(ChangeEventArgs e)
    {
        _userId = e.Value?.ToString() ?? "";
        await Config.SetSettingAsync("jellyfin-user-id", _userId);
        ShowMessage("Saved.", false);
    }

    private async Task SaveCastCrewEmail(ChangeEventArgs e)
    {
        _castCrewEmail = e.Value?.ToString() ?? "";
        await Config.SetSettingAsync("jellyfin-castcrew-notify-email", _castCrewEmail);
        ShowMessage("Saved.", false);
    }

    private async Task SaveRetention()
    {
        await Config.SetSettingAsync("jellyfin-backup-retention-days", _retentionDays.ToString());
        ShowMessage($"Backup retention set to {_retentionDays} days.", false);
    }

    private void RefreshDirectoryStats()
    {
        var backupDir = OperationLogger.GetBackupDirectory();
        if (Directory.Exists(backupDir))
        {
            var files = Directory.GetFiles(backupDir, "*.db");
            _backupCount = files.Length;
            _backupSize = files.Sum(f => new FileInfo(f).Length);
        }

        var logDir = OperationLogger.GetLogDirectory();
        if (Directory.Exists(logDir))
        {
            _logCount = Directory.GetFiles(logDir, "*.log").Length;
        }
    }

    private void ShowMessage(string msg, bool isError)
    {
        _message = msg;
        _messageIsError = isError;
        _ = Task.Delay(isError ? 10000 : 5000).ContinueWith(_ => InvokeAsync(() =>
        {
            _message = null;
            StateHasChanged();
        }));
    }

    private static string FormatSize(long bytes) => Services.FormatHelper.FormatSize(bytes);
}
