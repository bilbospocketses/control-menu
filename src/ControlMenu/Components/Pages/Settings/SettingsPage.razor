@page "/settings"
@page "/settings/{Section}"

<PageTitle>Settings — Control Menu</PageTitle>

<div class="settings-layout">
    <nav class="settings-nav">
        <button class="settings-nav-item @(ActiveSection == "general" ? "active" : "")"
                @onclick='() => Navigate("general")'>
            <i class="bi bi-gear"></i> General
        </button>
        <button class="settings-nav-item @(ActiveSection == "devices" ? "active" : "")"
                @onclick='() => Navigate("devices")'>
            <i class="bi bi-phone"></i> Devices
        </button>
        <button class="settings-nav-item @(ActiveSection == "jellyfin" ? "active" : "")"
                @onclick='() => Navigate("jellyfin")'>
            <i class="bi bi-film"></i> Jellyfin
        </button>
        <button class="settings-nav-item @(ActiveSection == "dependencies" ? "active" : "")"
                @onclick='() => Navigate("dependencies")'>
            <i class="bi bi-box-seam"></i> Dependencies
        </button>
        <button class="settings-nav-item @(ActiveSection == "cameras" ? "active" : "")"
                @onclick='() => Navigate("cameras")'>
            <i class="bi bi-camera-video"></i> Cameras
        </button>
    </nav>

    <div class="settings-content">
        @switch (ActiveSection)
        {
            case "general":
                <GeneralSettings />
                break;
            case "devices":
                <DeviceManagement />
                break;
            case "jellyfin":
                <JellyfinSettingsSection />
                break;
            case "dependencies":
                <DependencyManagement />
                break;
            case "cameras":
                <CameraSettings />
                break;
            default:
                <p>Unknown settings section. <a href="/settings/general">Go to General Settings</a></p>
                break;
        }
    </div>
</div>

@code {
    [Parameter]
    public string? Section { get; set; }

    [Inject]
    private NavigationManager Nav { get; set; } = default!;

    private string ActiveSection => Section?.ToLowerInvariant() ?? "general";

    private void Navigate(string section)
    {
        Nav.NavigateTo($"/settings/{section}");
    }
}
