@using ControlMenu.Services
@inject IConfigurationService Config
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IEmailService EmailService

<div class="settings-section">
    <h2>General</h2>

    <div class="form-group">
        <label>Theme</label>
        <div style="display:flex;gap:8px;align-items:center;">
            <button class="btn @(_theme == "dark" ? "btn-primary" : "btn-secondary")" @onclick='() => SetTheme("dark")'>
                <i class="bi bi-moon-fill"></i> Dark
            </button>
            <button class="btn @(_theme == "light" ? "btn-primary" : "btn-secondary")" @onclick='() => SetTheme("light")'>
                <i class="bi bi-sun-fill"></i> Light
            </button>
        </div>
    </div>

    <div class="form-group">
        <label>Setup Wizard</label>
        <button class="btn btn-secondary" @onclick="RerunWizard"><i class="bi bi-arrow-counterclockwise"></i> Re-run Setup Wizard</button>
        <div class="form-hint">Walk through the initial setup again.</div>
    </div>
</div>

<div class="settings-section" style="margin-top:2rem;">
    <h2>Email (SMTP)</h2>
    <p>Configure SMTP for sending notification emails from any module.</p>

    <div class="form-group">
        <label>SMTP Server</label>
        <input class="form-control" style="max-width:300px;" value="@_smtpServer"
               placeholder="mail.smtp2go.com" @onchange="SaveSmtpServer" />
    </div>
    <div class="form-group">
        <label>SMTP Port</label>
        <input type="number" class="form-control" style="max-width:100px;" value="@_smtpPort"
               @onchange="SaveSmtpPort" />
    </div>
    <div class="form-group">
        <label>Username</label>
        <input class="form-control" style="max-width:300px;" value="@_smtpUsername"
               @onchange="SaveSmtpUsername" />
    </div>
    <div class="form-group">
        <label>Password</label>
        <input type="password" class="form-control" style="max-width:300px;" value="@_smtpPassword"
               @onchange="SaveSmtpPassword" />
    </div>
    <div class="form-group">
        <label>From Email</label>
        <input type="email" class="form-control" style="max-width:300px;" value="@_fromEmail"
               placeholder="noreply@yourdomain.com" @onchange="SaveFromEmail" />
        <div class="form-hint">Sender address for outgoing emails. Must be authorized by your SMTP provider.</div>
    </div>
    <div class="form-group">
        <label>Notification Email</label>
        <input type="email" class="form-control" style="max-width:300px;" value="@_notificationEmail"
               placeholder="you@example.com" @onchange="SaveNotificationEmail" />
        <div class="form-hint">Default recipient for all notification emails.</div>
    </div>
    <div class="form-group">
        <button class="btn btn-secondary" @onclick="SendTestEmail" disabled="@_sendingTest">
            <i class="bi bi-envelope"></i> @(_sendingTest ? "Sending..." : "Send Test Email")
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_messageIsError ? "alert-danger" : "alert-success")" style="margin-top:1rem;">
        @_message
    </div>
}

@code {
    private string _theme = "dark";
    private string _smtpServer = "";
    private string _smtpPort = "587";
    private string _smtpUsername = "";
    private string _smtpPassword = "";
    private string _fromEmail = "";
    private string _notificationEmail = "";
    private bool _sendingTest;
    private string? _message;
    private bool _messageIsError;

    protected override async Task OnInitializedAsync()
    {
        _theme = await JS.InvokeAsync<string>("themeManager.get");
        _smtpServer = await Config.GetSettingAsync("smtp-server") ?? "";
        _smtpPort = await Config.GetSettingAsync("smtp-port") ?? "587";
        _smtpUsername = await Config.GetSettingAsync("smtp-username") ?? "";
        _smtpPassword = await Config.GetSecretAsync("smtp-password") ?? "";
        _fromEmail = await Config.GetSettingAsync("smtp-from-email") ?? "";
        _notificationEmail = await Config.GetSettingAsync("notification-email") ?? "";
    }

    private async Task SetTheme(string theme)
    {
        _theme = theme;
        await JS.InvokeVoidAsync("themeManager.set", theme);
        ShowMessage("Theme updated.", false);
    }

    private async Task SaveSmtpServer(ChangeEventArgs e)
    {
        _smtpServer = e.Value?.ToString() ?? "";
        await Config.SetSettingAsync("smtp-server", _smtpServer);
        ShowMessage("Saved.", false);
    }

    private async Task SaveSmtpPort(ChangeEventArgs e)
    {
        _smtpPort = e.Value?.ToString() ?? "587";
        await Config.SetSettingAsync("smtp-port", _smtpPort);
        ShowMessage("Saved.", false);
    }

    private async Task SaveSmtpUsername(ChangeEventArgs e)
    {
        _smtpUsername = e.Value?.ToString() ?? "";
        await Config.SetSettingAsync("smtp-username", _smtpUsername);
        ShowMessage("Saved.", false);
    }

    private async Task SaveSmtpPassword(ChangeEventArgs e)
    {
        _smtpPassword = e.Value?.ToString() ?? "";
        if (!string.IsNullOrEmpty(_smtpPassword))
        {
            await Config.SetSecretAsync("smtp-password", _smtpPassword);
            ShowMessage("Saved.", false);
        }
        else
        {
            await Config.DeleteSettingAsync("smtp-password");
            ShowMessage("Password cleared.", false);
        }
    }

    private async Task SaveFromEmail(ChangeEventArgs e)
    {
        _fromEmail = e.Value?.ToString() ?? "";
        await Config.SetSettingAsync("smtp-from-email", _fromEmail);
        ShowMessage("Saved.", false);
    }

    private async Task SaveNotificationEmail(ChangeEventArgs e)
    {
        _notificationEmail = e.Value?.ToString() ?? "";
        await Config.SetSettingAsync("notification-email", _notificationEmail);
        ShowMessage("Saved.", false);
    }

    private async Task SendTestEmail()
    {
        _sendingTest = true;
        _message = null;
        StateHasChanged();

        var (success, error) = await EmailService.SendTestAsync();
        _sendingTest = false;
        ShowMessage(success ? "Test email sent successfully!" : $"Failed: {error}", !success);
    }

    private void ShowMessage(string msg, bool isError)
    {
        _message = msg;
        _messageIsError = isError;
        _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() =>
        {
            _message = null;
            StateHasChanged();
        }));
    }

    private async Task RerunWizard()
    {
        await Config.SetSettingAsync("setup-completed", "false");
        Nav.NavigateTo("/", forceLoad: true);
    }
}
