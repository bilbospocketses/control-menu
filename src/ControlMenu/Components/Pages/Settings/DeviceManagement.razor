@using ControlMenu.Components.Shared.Scanner
@using ControlMenu.Data.Entities
@using ControlMenu.Data.Enums
@using ControlMenu.Modules.AndroidDevices.Services
@using ControlMenu.Services.Network
@inject IDeviceService DeviceService
@inject INetworkDiscoveryService NetworkDiscovery
@inject IAdbService AdbService
@inject IConfigurationService Config
@inject IScanLifecycleHandler Handler
@implements IDisposable

<div class="settings-section">
    <h2>Device Discovery</h2>
    <div class="form-group" style="margin-bottom:1.5rem;">
        <label>Discovery Interval (seconds)</label>
        <input type="number" class="form-control" style="max-width:200px;" min="30" max="3600"
               value="@_discoveryInterval" @onchange="OnDiscoveryIntervalChanged" />
        <div class="form-hint">How often to scan the network for device IP changes. Min 30s, max 3600s.</div>
    </div>
</div>

<div class="settings-section">
    <h2>Device Management</h2>
    <p>Register and manage Android devices. <strong>Quick Refresh</strong> reconciles registered devices via <code>adb mdns services</code> + ARP; <strong>Scan Network…</strong> opens a full scanner (CIDR/IP/range subnets, TCP sweep + mDNS via ws-scrcpy-web).</p>

    <div class="toolbar">
        <button class="btn btn-primary" @onclick="ShowAddForm">
            <i class="bi bi-plus-lg"></i> Add Device
        </button>
        <button class="btn btn-secondary" @onclick="QuickRefresh" disabled="@_scanning">
            <i class="bi bi-arrow-clockwise"></i> @(_scanning ? "Refreshing..." : "Quick Refresh")
        </button>
        <button class="btn btn-secondary" @onclick="OpenScanModal">
            <i class="bi bi-broadcast"></i> Scan Network…
        </button>
    </div>

    @if (_devices.Count == 0)
    {
        <p style="color: var(--text-muted);">No devices registered. Click "Add Device" to get started.</p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th style="min-width:70px;">Status</th>
                    <th style="min-width:125px;">Name</th>
                    <th style="min-width:130px;">Type</th>
                    <th style="min-width:135px;">MAC Address</th>
                    <th style="min-width:130px;">IP Address</th>
                    <th style="min-width:75px;">ADB Port</th>
                    <th style="min-width:150px;">Serial</th>
                    <th style="min-width:80px; text-align:center;">PIN?</th>
                    <th style="min-width:110px;">Last Seen</th>
                    <th style="min-width:130px; text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var device in _devices)
                {
                    <tr>
                        <td><span class="status-dot @GetStatusClass(device)"></span></td>
                        <td>@device.Name</td>
                        <td>@device.Type</td>
                        <td><code>@device.MacAddress</code></td>
                        <td>@(device.LastKnownIp ?? "—")</td>
                        <td>@device.AdbPort</td>
                        <td>@(device.SerialNumber ?? "—")</td>
                        <td style="text-align:center;">
                            @if (_deviceHasPin.TryGetValue(device.Id, out var hasPin) && hasPin)
                            {
                                <span style="color: var(--success-color); font-weight: bold;" title="PIN is set">✓</span>
                            }
                        </td>
                        <td>@FormatLastSeen(device.LastSeen)</td>
                        <td class="actions">
                            <button class="btn btn-secondary btn-sm" @onclick="() => ShowEditForm(device)">Edit</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => ConfirmDelete(device)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (Handler.Phase is not ScanPhase.Idle)
{
    <div class="scan-row">
        <ScanProgressChip Phase="Handler.Phase"
                          Checked="Handler.LastProgress?.Checked ?? 0"
                          Total="Handler.LastProgress?.Total ?? 0"
                          FoundSoFar="Handler.Discovered.Count" />
        @if (Handler.Phase is ScanPhase.Scanning or ScanPhase.Draining)
        {
            <button class="btn btn-warning btn-sm" @onclick="Handler.CancelScanAsync">Cancel</button>
        }
    </div>
}

<DiscoveredPanel Discovered="Handler.Discovered"
                 StashedNamesByMac="Handler.StashedNamesByMac"
                 Registered="_devices"
                 OnAdd="HandleInlineAdd"
                 OnDismiss="Handler.Dismiss" />

@if (_showForm)
{
    <DeviceForm Model="_formDevice" IsEdit="_isEditing" @bind-Pin="_formPin" OnSave="SaveDevice" OnCancel="CloseForm" />
}

@if (_showScanModal)
{
    <ScanNetworkModal OnStart="OnFullScanStart"
                      OnClose="CloseScanModal"
                      ScanInProgress="@(Handler.Phase is ScanPhase.Scanning or ScanPhase.Draining)" />
}

@if (_showDeleteConfirm)
{
    <div class="dialog-overlay" @onclick="CloseDeleteConfirm">
        <div class="dialog" @onclick:stopPropagation="true">
            <h3>Delete Device</h3>
            <p>Are you sure you want to delete <strong>@_deleteTarget?.Name</strong>?</p>
            <div class="dialog-actions">
                <button class="btn btn-secondary" @onclick="CloseDeleteConfirm">Cancel</button>
                <button class="btn btn-danger" @onclick="DeleteDevice">Delete</button>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_messageIsError ? "alert-danger" : "alert-success")" style="margin-top:1rem;">
        @_message
    </div>
}

@code {
    private List<ControlMenu.Data.Entities.Device> _devices = [];
    private readonly Dictionary<Guid, bool> _deviceHasPin = new();
    private bool _showForm;
    private bool _isEditing;
    private ControlMenu.Data.Entities.Device _formDevice = new()
    {
        Name = "", MacAddress = "", ModuleId = "android-devices"
    };
    private string _formPin = "";
    private bool _showDeleteConfirm;
    private ControlMenu.Data.Entities.Device? _deleteTarget;
    private bool _scanning;
    private bool _showScanModal;
    private string? _message;

    private bool _messageIsError;
    private int _discoveryInterval = 300;

    protected override async Task OnInitializedAsync()
    {
        var interval = await Config.GetSettingAsync("discovery-interval");
        if (int.TryParse(interval, out var parsed))
            _discoveryInterval = parsed;
        await LoadDevices();
        Handler.OnStateChanged += HandleHandlerStateChanged;
    }

    private void HandleHandlerStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            var err = Handler.ConsumeLastError();
            if (err is not null)
                await ShowMessage(err, isError: true);
            StateHasChanged();
        });
    }

    private async Task OnDiscoveryIntervalChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val) && val >= 30 && val <= 3600)
        {
            _discoveryInterval = val;
            await Config.SetSettingAsync("discovery-interval", val.ToString());
            await ShowMessage("Saved.");
        }
        else
        {
            await ShowMessage("Must be between 30 and 3600 seconds.", true);
        }
    }

    private async Task LoadDevices()
    {
        _devices = (await DeviceService.GetAllDevicesAsync()).ToList();
        _deviceHasPin.Clear();
        foreach (var d in _devices)
        {
            var pin = await Config.GetSecretAsync($"device-pin-{d.Id}");
            _deviceHasPin[d.Id] = !string.IsNullOrEmpty(pin);
        }
    }

    private void ShowAddForm()
    {
        _formDevice = new ControlMenu.Data.Entities.Device
        {
            Name = "", MacAddress = "", ModuleId = "android-devices"
        };
        _formPin = "";
        _isEditing = false;
        _showForm = true;
    }

    private async Task ShowEditForm(ControlMenu.Data.Entities.Device device)
    {
        _formDevice = new ControlMenu.Data.Entities.Device
        {
            Id = device.Id,
            Name = device.Name,
            Type = device.Type,
            AdbPort = device.AdbPort,
            MacAddress = device.MacAddress,
            SerialNumber = device.SerialNumber,
            ModuleId = device.ModuleId,
            LastKnownIp = device.LastKnownIp,
            LastSeen = device.LastSeen,
            Metadata = device.Metadata
        };
        _formPin = await Config.GetSecretAsync($"device-pin-{device.Id}") ?? "";
        _isEditing = true;
        _showForm = true;
    }

    private void CloseForm()
    {
        _showForm = false;
    }

    private async Task SaveDevice()
    {
        try
        {
            _formDevice.MacAddress = NetworkDiscoveryService.NormalizeMac(_formDevice.MacAddress);
            var isEdit = _isEditing;
            _showForm = false;

            if (isEdit)
                await DeviceService.UpdateDeviceAsync(_formDevice);
            else
                await DeviceService.AddDeviceAsync(_formDevice);

            await LoadDevices();

            // Save or clear the PIN as an encrypted secret
            var savedDevice = isEdit ? _formDevice : _devices.FirstOrDefault(d => d.MacAddress == _formDevice.MacAddress);
            if (savedDevice is not null && !string.IsNullOrEmpty(_formPin))
                await Config.SetSecretAsync($"device-pin-{savedDevice.Id}", _formPin);
            else if (savedDevice is not null && string.IsNullOrEmpty(_formPin))
                await Config.SetSettingAsync($"device-pin-{savedDevice.Id}", "");

            // A newly added device claims its MAC from the discovery panel —
            // drop the matching row so the user doesn't see the same device
            // offered for adding a second time.
            if (!isEdit && !string.IsNullOrEmpty(_formDevice.MacAddress))
            {
                Handler.ReplaceDiscovered(Handler.Discovered
                    .Where(disc => !string.Equals(disc.Mac, _formDevice.MacAddress, StringComparison.OrdinalIgnoreCase)));
            }

            await ShowMessage($"Device {(isEdit ? "updated" : "added")} successfully.");
        }
        catch (Exception ex)
        {
            _showForm = false;
            var op = _isEditing ? "Update" : "Add";
            await ShowMessage($"{op} failed (Id={_formDevice.Id}): {ex.Message}", isError: true);
        }
    }

    private void ConfirmDelete(ControlMenu.Data.Entities.Device device)
    {
        _deleteTarget = device;
        _showDeleteConfirm = true;
    }

    private void CloseDeleteConfirm()
    {
        _showDeleteConfirm = false;
        _deleteTarget = null;
    }

    private async Task DeleteDevice()
    {
        if (_deleteTarget is not null)
        {
            // Remember the user-assigned name keyed by MAC. If the same device
            // is later rediscovered via mDNS and re-added, DiscoveredPanelRow
            // restores this name instead of falling back to the ADB product
            // model (which would read e.g. "Pixel 9" instead of "Jamie's phone").
            if (!string.IsNullOrEmpty(_deleteTarget.MacAddress))
            {
                await Config.SetSettingAsync($"device-name-{_deleteTarget.MacAddress}", _deleteTarget.Name);
            }
            await DeviceService.DeleteDeviceAsync(_deleteTarget.Id);
            _showDeleteConfirm = false;
            _deleteTarget = null;
            await LoadDevices();
            await ShowMessage("Device deleted.");
        }
    }

    private async Task QuickRefresh()
    {
        _scanning = true;
        StateHasChanged();

        // 1. Query mDNS — each hit gives us IP + advertised ADB port + service name.
        var mdnsResults = await AdbService.ScanMdnsAsync();

        // 2. Build IP→MAC map from ARP. If any mDNS IPs aren't in ARP yet, ping them
        //    in parallel to force the OS to resolve them, then re-read ARP.
        var arpMap = await BuildArpMapAsync();
        var missing = mdnsResults.Where(m => !arpMap.ContainsKey(m.IpAddress)).Select(m => m.IpAddress).ToList();
        if (missing.Count > 0)
        {
            await Task.WhenAll(missing.Select(ip => NetworkDiscovery.PingAsync(ip)));
            arpMap = await BuildArpMapAsync();
        }

        // 3. Walk the mDNS hits. Registered devices: update IP/port in-place in the DB
        //    (no entry in the Discovered panel). Unregistered devices: merge into the panel
        //    (preserving non-mDNS entries from a prior Full Scan and respecting dismissed).
        var devicesByMac = _devices.ToDictionary(d => d.MacAddress, d => d, StringComparer.OrdinalIgnoreCase);

        // Merge semantics: start with the existing Discovered snapshot so non-mDNS
        // entries (adb-merge rows, earlier Full Scan TCP hits) survive a Quick Refresh.
        // Quick Refresh adds mDNS-visible devices that aren't already registered,
        // aren't dismissed, and aren't duplicates by IP:port.
        var merged = new List<DiscoveredDevice>(Handler.Discovered);
        var mergedKeys = new HashSet<string>(
            merged.Select(d => ScanMergeHelper.AddressKey(d.Ip, d.Port)),
            StringComparer.OrdinalIgnoreCase);

        var coveredRegistered = new HashSet<Guid>();
        int updated = 0;
        int portUpdated = 0;
        int newOnes = 0;
        foreach (var m in mdnsResults)
        {
            var mac = arpMap.TryGetValue(m.IpAddress, out var x) ? x : null;
            if (mac is not null && devicesByMac.TryGetValue(mac, out var registered))
            {
                await DeviceService.UpdateLastSeenAsync(registered.Id, m.IpAddress);
                if (registered.AdbPort != m.Port)
                {
                    registered.AdbPort = m.Port;
                    await DeviceService.UpdateDeviceAsync(registered);
                    portUpdated++;
                }
                coveredRegistered.Add(registered.Id);
                updated++;
                continue;
            }

            var key = ScanMergeHelper.AddressKey(m.IpAddress, m.Port);

            // Respect dismissed set for the current scan session.
            if (Handler.DismissedAddresses.Contains(key))
                continue;

            // Dedupe against existing Discovered entries (including anything carried
            // over from a prior Full Scan).
            if (mergedKeys.Contains(key))
                continue;

            merged.Add(new DiscoveredDevice(m.ServiceName, m.IpAddress, m.Port, mac, Source: "mdns"));
            mergedKeys.Add(key);
            newOnes++;
        }

        // 4. For registered devices not seen via mDNS, fall back to ARP-only IP refresh.
        foreach (var device in _devices.Where(d => !coveredRegistered.Contains(d.Id)))
        {
            var ip = await NetworkDiscovery.ResolveIpFromMacAsync(device.MacAddress);
            if (ip is not null)
            {
                await DeviceService.UpdateLastSeenAsync(device.Id, ip);
                updated++;
            }
        }

        Handler.ReplaceDiscovered(merged);
        await LoadDevices();
        _scanning = false;

        var parts = new List<string> { $"{updated} of {_devices.Count} registered device(s) found" };
        if (portUpdated > 0) parts.Add($"{portUpdated} ADB port(s) updated from mDNS");
        if (newOnes > 0) parts.Add($"{newOnes} new device(s) on network");
        await ShowMessage($"Scan complete. {string.Join("; ", parts)}.");
    }

    private async Task<Dictionary<string, string>> BuildArpMapAsync()
    {
        var entries = await NetworkDiscovery.GetArpTableAsync();
        return entries
            .GroupBy(e => e.IpAddress)
            .ToDictionary(g => g.Key, g => g.First().MacAddress, StringComparer.OrdinalIgnoreCase);
    }

    // Called when a DiscoveredPanelRow fires its OnAdd after the user clicks
    // the row's inline Add button. Unpacks the payload into _formDevice/_formPin
    // and delegates to the existing SaveDevice path — which handles MAC
    // normalization, AddDeviceAsync persistence, PIN secret-storage, and the
    // "drop added MAC from Handler.Discovered" filter.
    private async Task HandleInlineAdd(InlineAddPayload payload)
    {
        _formDevice = payload.Device;
        _formPin = payload.Pin;
        _isEditing = false;
        await SaveDevice();
    }

    private static string GetStatusClass(ControlMenu.Data.Entities.Device device)
    {
        if (device.LastSeen is null) return "offline";
        var age = DateTime.UtcNow - device.LastSeen.Value;
        if (age.TotalMinutes < 10) return "online";
        if (age.TotalHours < 24) return "stale";
        return "offline";
    }

    private static string FormatLastSeen(DateTime? lastSeen)
    {
        if (lastSeen is null) return "Never";
        var age = DateTime.UtcNow - lastSeen.Value;
        if (age.TotalMinutes < 1) return "Just now";
        if (age.TotalMinutes < 60) return $"{(int)age.TotalMinutes}m ago";
        if (age.TotalHours < 24) return $"{(int)age.TotalHours}h ago";
        return lastSeen.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }

    private void OpenScanModal() => _showScanModal = true;
    private void CloseScanModal() => _showScanModal = false;

    private Task OnFullScanStart(IReadOnlyList<ParsedSubnet> subnets)
        => Handler.StartFullScanAsync(subnets);


    private async Task ShowMessage(string message, bool isError = false)
    {
        _message = message;
        _messageIsError = isError;
        StateHasChanged();
        await Task.Delay(isError ? 10000 : 5000);
        _message = null;
        StateHasChanged();
    }

    public void Dispose()
    {
        Handler.OnStateChanged -= HandleHandlerStateChanged;
    }
}
