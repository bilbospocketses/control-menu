@using ControlMenu.Modules.Cameras
@using ControlMenu.Modules.Cameras.Services

<h2>Cameras</h2>
<p>Configure your CCTV cameras. Each camera needs a name, IP address, and login credentials.</p>

<div class="form-row" style="margin-bottom: 1rem;">
    <label>Number of cameras</label>
    <div style="display: flex; align-items: center; gap: 0.75rem;">
        <input class="form-control" type="number" min="1" value="@_cameraCount"
               @onchange="OnCountChanged" style="width: 80px;" />
        @if (_countSaved)
        {
            <span class="save-confirm">Saved — refresh page to update sidebar</span>
        }
    </div>
</div>

@for (var i = 1; i <= _cameraCount; i++)
{
    var index = i;
    <div class="camera-settings-card">
        <h3>Camera @index</h3>
        <div class="form-row">
            <label>Name</label>
            <input class="form-control" value="@GetValue(_names, index)"
                   @onchange="e => _names[index] = e.Value?.ToString() ?? string.Empty"
                   placeholder="e.g. Front Door" />
        </div>
        <div class="form-row">
            <label>IP Address</label>
            <input class="form-control" value="@GetValue(_ips, index)"
                   @onchange="e => _ips[index] = e.Value?.ToString() ?? string.Empty"
                   placeholder="e.g. 192.168.86.101" />
        </div>
        <div class="form-row">
            <label>RTSP Port</label>
            <input class="form-control" type="number" value="@GetIntValue(_ports, index, 554)"
                   @onchange="e => _ports[index] = int.TryParse(e.Value?.ToString(), out var p) ? p : 554"
                   placeholder="554" />
        </div>
        <div class="form-row">
            <label>Username</label>
            <input class="form-control" value="@GetValue(_usernames, index)"
                   @onchange="e => _usernames[index] = e.Value?.ToString() ?? string.Empty"
                   placeholder="admin" />
        </div>
        <div class="form-row">
            <label>Password</label>
            <input class="form-control" type="password" value="@GetValue(_passwords, index)"
                   @onchange="e => _passwords[index] = e.Value?.ToString() ?? string.Empty"
                   placeholder="password" />
        </div>
        <button class="btn btn-secondary" @onclick="() => SaveCamera(index)" disabled="@_saving">
            <i class="bi bi-check-lg"></i> Save Camera @index
        </button>
        @if (_savedIndex == index)
        {
            <span class="save-confirm">Saved</span>
        }
    </div>
}

@code {
    [Inject] private ICameraService CameraService { get; set; } = default!;
    [Inject] private IGo2RtcService Go2Rtc { get; set; } = default!;

    private int _cameraCount;
    private bool _countSaved;
    private readonly Dictionary<int, string> _names = new();
    private readonly Dictionary<int, string> _ips = new();
    private readonly Dictionary<int, int> _ports = new();
    private readonly Dictionary<int, string> _usernames = new();
    private readonly Dictionary<int, string> _passwords = new();
    private bool _saving;
    private int? _savedIndex;

    protected override async Task OnInitializedAsync()
    {
        _cameraCount = await CameraService.GetCameraCountAsync();
        for (var i = 1; i <= _cameraCount; i++)
            await LoadCamera(i);
    }

    private async Task LoadCamera(int i)
    {
        var cam = await CameraService.GetCameraAsync(i);
        _names[i] = cam?.Name ?? "";
        _ips[i] = cam?.IpAddress ?? "";
        _ports[i] = cam?.Port ?? 554;

        var creds = await CameraService.GetCredentialsAsync(i);
        _usernames[i] = creds?.Username ?? "";
        _passwords[i] = creds?.Password ?? "";
    }

    private async Task OnCountChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var count) && count >= 1)
        {
            var oldCount = _cameraCount;
            _cameraCount = count;
            await CameraService.SetCameraCountAsync(count);
            CamerasModule.CameraCount = count;

            // Load any new slots
            for (var i = oldCount + 1; i <= count; i++)
                await LoadCamera(i);

            _countSaved = true;
        }
    }

    private async Task SaveCamera(int index)
    {
        _saving = true;
        _savedIndex = null;
        _countSaved = false;
        StateHasChanged();

        if (!string.IsNullOrWhiteSpace(GetValue(_names, index)) && !string.IsNullOrWhiteSpace(GetValue(_ips, index)))
        {
            await CameraService.SaveCameraAsync(index, _names[index].Trim(), _ips[index].Trim(), GetIntValue(_ports, index, 554));
        }
        if (!string.IsNullOrWhiteSpace(GetValue(_usernames, index)) && !string.IsNullOrWhiteSpace(GetValue(_passwords, index)))
        {
            await CameraService.SaveCredentialsAsync(index, _usernames[index], _passwords[index]);
        }

        await Go2Rtc.RegenerateConfigAsync();

        _savedIndex = index;
        _saving = false;
    }

    private static string GetValue(Dictionary<int, string> dict, int key) =>
        dict.TryGetValue(key, out var val) ? val : "";

    private static int GetIntValue(Dictionary<int, int> dict, int key, int fallback) =>
        dict.TryGetValue(key, out var val) ? val : fallback;
}
