@inject IDependencyManagerService DepManager

<div class="settings-section">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
        <h2>Dependencies</h2>
        <div class="toolbar">
            <button class="btn btn-secondary btn-sm" @onclick="RescanAsync" disabled="@_scanning">
                <i class="bi bi-arrow-clockwise"></i> Re-scan
            </button>
        </div>
    </div>
    <p>Required tools are checked on your system PATH and in the app's <code>dependencies/</code> folder.</p>

    @if (_scanning)
    {
        <p><i class="bi bi-hourglass-split"></i> Scanning...</p>
    }
    else if (_results.Count > 0)
    {
        @* --- External dependencies (not configurable path) --- *@
        var external = _results.Where(r => !DepManager.IsConfigurable(r.Name, r.ModuleId)).ToList();
        @if (external.Count > 0)
        {
            <h3 style="margin-top:1rem; font-size:0.95rem; color:var(--text-secondary);">External (installed separately)</h3>
            <table class="data-table">
                <thead>
                    <tr><th>Tool</th><th>Status</th><th>Version</th><th>Action</th></tr>
                </thead>
                <tbody>
                    @foreach (var result in external)
                    {
                        <tr>
                            <td>@result.Name</td>
                            <td>
                                @if (result.Found)
                                {
                                    <span class="status-badge status-ok">Found</span>
                                }
                                else
                                {
                                    <span class="status-badge status-error">Not Found</span>
                                }
                            </td>
                            <td>@(result.Version ?? "—")</td>
                            <td>
                                @if (result.Found)
                                {
                                    <span style="color: var(--success-color);"><i class="bi bi-check-circle-fill"></i> OK</span>
                                }
                                else
                                {
                                    <span style="color:var(--text-muted); font-size:0.85rem;">Install manually</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @* --- Managed dependencies (configurable install path) --- *@
        var managed = _results.Where(r => DepManager.IsConfigurable(r.Name, r.ModuleId)).ToList();
        @if (managed.Count > 0)
        {
            <h3 style="margin-top:1.5rem; font-size:0.95rem; color:var(--text-secondary);">Managed (auto-installable)</h3>
            <table class="data-table">
                <thead>
                    <tr><th>Tool</th><th>Status</th><th>Version</th><th>Install Path</th><th>Action</th></tr>
                </thead>
                <tbody>
                    @foreach (var result in managed)
                    {
                        var depPath = _installPaths.GetValueOrDefault(result.Name, "");
                        <tr>
                            <td>@result.Name</td>
                            <td>
                                @if (result.Found)
                                {
                                    <span class="status-badge status-ok">Found</span>
                                }
                                else
                                {
                                    <span class="status-badge status-error">Not Found</span>
                                }
                            </td>
                            <td>@(result.Version ?? "—")</td>
                            <td>
                                <div style="display:flex; gap:0.4rem; align-items:center;">
                                    <input class="form-control" style="min-width:240px; font-size:0.85rem;"
                                           value="@depPath"
                                           @onchange="e => OnPathChanged(result.Name, e)" />
                                    <button class="btn btn-secondary btn-sm" title="Reset to default"
                                            @onclick="() => ResetPath(result.Name, result.ModuleId)">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                    </button>
                                </div>
                            </td>
                            <td>
                                @if (result.Found)
                                {
                                    <span style="color: var(--success-color);"><i class="bi bi-check-circle-fill"></i> OK</span>
                                }
                                else if (_installing.Contains(result.Name))
                                {
                                    <span style="color:var(--text-muted);"><i class="bi bi-hourglass-split"></i> Installing...</span>
                                }
                                else if (DepManager.CanAutoInstall(result.Name, result.ModuleId))
                                {
                                    <button class="btn btn-primary btn-sm" @onclick="() => InstallAsync(result)">
                                        <i class="bi bi-download"></i> Install
                                    </button>
                                }
                                else
                                {
                                    <span style="color:var(--text-muted); font-size:0.85rem;">Manual</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="form-hint" style="margin-top: 0.75rem; color: @(_messageIsError ? "var(--danger-color)" : "var(--success-color)");">
            @_message
        </div>
    }
</div>

@code {
    [Parameter] public SetupWizard.WizardState State { get; set; } = default!;

    private List<DependencyScanResult> _results = [];
    private readonly HashSet<string> _installing = new();
    private Dictionary<string, string> _installPaths = new();
    private bool _scanning = true;
    private string? _message;
    private bool _messageIsError;

    protected override async Task OnInitializedAsync()
    {
        await RunScanAsync();
    }

    private async Task RescanAsync()
    {
        _scanning = true;
        _message = null;
        await RunScanAsync();
    }

    private async Task RunScanAsync()
    {
        _scanning = true;
        _results = (await DepManager.ScanForDependenciesAsync()).ToList();

        // Load install paths for configurable dependencies
        _installPaths.Clear();
        foreach (var r in _results.Where(r => DepManager.IsConfigurable(r.Name, r.ModuleId)))
        {
            var path = await DepManager.GetInstallPathAsync(r.Name, r.ModuleId);
            _installPaths[r.Name] = path ?? "";
        }

        _scanning = false;
        UpdateState();
    }

    private async Task OnPathChanged(string name, ChangeEventArgs e)
    {
        var newPath = e.Value?.ToString()?.Trim() ?? "";
        _installPaths[name] = newPath;
        if (!string.IsNullOrEmpty(newPath))
            await DepManager.SetInstallPathAsync(name, newPath);
    }

    private async Task ResetPath(string name, string moduleId)
    {
        // Clear custom override so it falls back to module default
        await DepManager.SetInstallPathAsync(name, "");
        var defaultPath = DepManager.GetInstallPath(name, moduleId) ?? "";
        _installPaths[name] = defaultPath;
    }

    private async Task InstallAsync(DependencyScanResult dep)
    {
        // Save the current path before installing
        var path = _installPaths.GetValueOrDefault(dep.Name, "");
        if (!string.IsNullOrEmpty(path))
            await DepManager.SetInstallPathAsync(dep.Name, path);

        _installing.Add(dep.Name);
        _message = $"Installing {dep.Name}...";
        _messageIsError = false;
        StateHasChanged();

        try
        {
            var allDeps = await DepManager.GetAllDependenciesAsync();
            var entity = allDeps.FirstOrDefault(d => d.Name == dep.Name && d.ModuleId == dep.ModuleId);
            if (entity is null)
            {
                _message = $"Could not find {dep.Name} in database.";
                _messageIsError = true;
                return;
            }

            var asset = await DepManager.ResolveDownloadAssetAsync(entity.Id);
            if (asset is null)
            {
                _message = $"Could not find a download for {dep.Name} on this platform.";
                _messageIsError = true;
                return;
            }

            var result = await DepManager.DownloadAndInstallAsync(entity.Id, asset);
            if (result.Success)
            {
                _message = $"{dep.Name} v{result.NewVersion} installed to {_installPaths.GetValueOrDefault(dep.Name, "")}";
                _messageIsError = false;
                await RunScanAsync();
            }
            else
            {
                _message = $"Failed to install {dep.Name}: {result.ErrorMessage}";
                _messageIsError = true;
            }
        }
        catch (Exception ex)
        {
            _message = $"Error installing {dep.Name}: {ex.Message}";
            _messageIsError = true;
        }
        finally
        {
            _installing.Remove(dep.Name);
        }
    }

    private void UpdateState()
    {
        State.DependenciesTotal = _results.Count;
        State.DependenciesFound = _results.Count(r => r.Found);
    }
}
