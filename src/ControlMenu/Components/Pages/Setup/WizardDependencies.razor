@inject IDependencyManagerService DepManager

<div class="settings-section">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
        <h2>Locate Dependencies</h2>
        <div class="toolbar">
            <button class="btn btn-secondary btn-sm" @onclick="RescanAsync" disabled="@_scanning">
                <i class="bi bi-arrow-clockwise"></i> Re-scan
            </button>
        </div>
    </div>
    <p>Required tools are auto-installed to the app's <code>dependencies/</code> folder. We also check your system PATH.</p>

    @if (_scanning)
    {
        <p><i class="bi bi-hourglass-split"></i> Scanning...</p>
    }
    else if (_results.Count > 0)
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Tool</th>
                    <th>Status</th>
                    <th>Version</th>
                    <th>Location</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var result in _results)
                {
                    <tr>
                        <td>@result.Name</td>
                        <td>
                            @if (result.Found)
                            {
                                <span class="status-badge status-ok">Found</span>
                            }
                            else
                            {
                                <span class="status-badge status-error">Not Found</span>
                            }
                        </td>
                        <td>@(result.Version ?? "—")</td>
                        <td style="font-size:0.85rem;">
                            @if (result.Found)
                            {
                                @(result.Path ?? result.Source)
                            }
                            else
                            {
                                var installPath = DepManager.GetInstallPath(result.Name, result.ModuleId);
                                @if (installPath is not null)
                                {
                                    <span style="color:var(--text-muted);">@installPath</span>
                                }
                                else
                                {
                                    <span style="color:var(--text-muted);">Manual install required</span>
                                }
                            }
                        </td>
                        <td>
                            @if (result.Found)
                            {
                                @if (_accepted.Contains(result.Name))
                                {
                                    <span style="color: var(--success-color);">
                                        <i class="bi bi-check-circle-fill"></i> OK
                                    </span>
                                }
                                else
                                {
                                    <button class="btn btn-primary btn-sm" @onclick="() => Accept(result.Name)">Accept</button>
                                }
                            }
                            else if (_installing.Contains(result.Name))
                            {
                                <span style="color:var(--text-muted);"><i class="bi bi-hourglass-split"></i> Installing...</span>
                            }
                            else if (DepManager.CanAutoInstall(result.Name, result.ModuleId))
                            {
                                <button class="btn btn-primary btn-sm" @onclick="() => InstallAsync(result)">
                                    <i class="bi bi-download"></i> Install
                                </button>
                            }
                            else
                            {
                                @if (_editing.Contains(result.Name))
                                {
                                    <div style="display: flex; gap: 0.4rem; align-items: center;">
                                        <input class="form-control"
                                               style="max-width: 260px;"
                                               placeholder="Path to executable..."
                                               @bind="_manualPaths[result.Name]" />
                                        <button class="btn btn-primary btn-sm" @onclick="() => OkManualPath(result.Name)">OK</button>
                                        <button class="btn btn-secondary btn-sm" @onclick="() => CancelManualPath(result.Name)">Cancel</button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-secondary btn-sm" @onclick="() => StartEditing(result.Name)">Enter Path...</button>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="form-hint" style="margin-top: 0.75rem; color: @(_messageIsError ? "var(--danger-color)" : "var(--success-color)");">
            @_message
        </div>
    }
</div>

@code {
    [Parameter] public SetupWizard.WizardState State { get; set; } = default!;

    private List<DependencyScanResult> _results = [];
    private readonly HashSet<string> _accepted = new();
    private readonly HashSet<string> _editing = new();
    private readonly HashSet<string> _installing = new();
    private readonly Dictionary<string, string> _manualPaths = new();
    private bool _scanning = true;
    private string? _message;
    private bool _messageIsError;

    protected override async Task OnInitializedAsync()
    {
        await RunScanAsync();
    }

    private async Task RescanAsync()
    {
        _scanning = true;
        _accepted.Clear();
        _editing.Clear();
        _manualPaths.Clear();
        _message = null;
        await RunScanAsync();
    }

    private async Task RunScanAsync()
    {
        _scanning = true;
        _results = (await DepManager.ScanForDependenciesAsync()).ToList();

        foreach (var r in _results.Where(r => r.Found))
            _accepted.Add(r.Name);

        _scanning = false;
        UpdateState();
    }

    private void Accept(string name)
    {
        _accepted.Add(name);
        UpdateState();
    }

    private void StartEditing(string name)
    {
        _editing.Add(name);
        var installPath = _results.FirstOrDefault(r => r.Name == name) is { } res
            ? DepManager.GetInstallPath(res.Name, res.ModuleId) ?? ""
            : "";
        _manualPaths.TryAdd(name, installPath);
    }

    private async Task OkManualPath(string name)
    {
        _editing.Remove(name);
        if (!_manualPaths.TryGetValue(name, out var path) || string.IsNullOrWhiteSpace(path))
            return;

        var dep = _results.FirstOrDefault(r => r.Name == name);
        if (dep is null) return;

        var validated = await DepManager.ValidateManualPathAsync(name, dep.ModuleId, path.Trim());
        if (validated is not null)
        {
            _results = _results.Select(r => r.Name == name ? validated : r).ToList();
            _accepted.Add(name);
            _message = $"{name} found at {path.Trim()}";
            _messageIsError = false;
            UpdateState();
        }
        else
        {
            _message = $"Could not validate {name} at {path.Trim()} — check the path and try again.";
            _messageIsError = true;
        }
    }

    private void CancelManualPath(string name)
    {
        _editing.Remove(name);
    }

    private async Task InstallAsync(DependencyScanResult dep)
    {
        _installing.Add(dep.Name);
        _message = $"Installing {dep.Name}...";
        _messageIsError = false;
        StateHasChanged();

        try
        {
            // Find DB entity for this dependency
            var allDeps = await DepManager.GetAllDependenciesAsync();
            var entity = allDeps.FirstOrDefault(d => d.Name == dep.Name && d.ModuleId == dep.ModuleId);
            if (entity is null)
            {
                _message = $"Could not find {dep.Name} in database.";
                _messageIsError = true;
                return;
            }

            // Resolve download asset
            var asset = await DepManager.ResolveDownloadAssetAsync(entity.Id);
            if (asset is null)
            {
                _message = $"Could not find a download for {dep.Name} on this platform.";
                _messageIsError = true;
                return;
            }

            // Download and install
            var result = await DepManager.DownloadAndInstallAsync(entity.Id, asset);
            if (result.Success)
            {
                _message = $"{dep.Name} v{result.NewVersion} installed successfully.";
                _messageIsError = false;

                // Refresh scan results to reflect the install
                await RunScanAsync();
            }
            else
            {
                _message = $"Failed to install {dep.Name}: {result.ErrorMessage}";
                _messageIsError = true;
            }
        }
        catch (Exception ex)
        {
            _message = $"Error installing {dep.Name}: {ex.Message}";
            _messageIsError = true;
        }
        finally
        {
            _installing.Remove(dep.Name);
        }
    }

    private void UpdateState()
    {
        State.DependenciesTotal = _results.Count;
        State.DependenciesFound = _results.Count(r => r.Found);
    }
}
