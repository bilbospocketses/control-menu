<div class="done-container">
    <i class="bi bi-check-circle-fill done-icon"></i>

    <h2 class="done-heading">Setup Complete</h2>

    <p class="done-description">
        Here's a summary of what was configured. You can always change these in Settings.
    </p>

    <div class="summary-list">

        <!-- Devices -->
        <div class="summary-item">
            @if (State.DevicesAdded > 0)
            {
                <i class="bi bi-check-circle-fill text-ok summary-icon"></i>
                <span>@State.DevicesAdded device(s) registered</span>
            }
            else
            {
                <i class="bi bi-exclamation-triangle-fill text-warning summary-icon"></i>
                <span>No devices registered — <a href="/settings/devices">add in Settings</a></span>
            }
        </div>

        <!-- Jellyfin -->
        <div class="summary-item">
            @if (State.JellyfinConfigured)
            {
                <i class="bi bi-check-circle-fill text-ok summary-icon"></i>
                <span>Jellyfin configured</span>
            }
            else
            {
                <i class="bi bi-dash-circle summary-icon text-neutral"></i>
                <span>Jellyfin not configured — <a href="/settings/jellyfin">set up in Settings</a></span>
            }
        </div>

        <!-- Email -->
        <div class="summary-item">
            @if (State.SmtpConfigured)
            {
                <i class="bi bi-check-circle-fill text-ok summary-icon"></i>
                <span>Email notifications configured</span>
            }
            else
            {
                <i class="bi bi-dash-circle summary-icon text-neutral"></i>
                <span>Email not configured — <a href="/settings/general">set up in Settings</a></span>
            }
        </div>

        <!-- Dependencies -->
        <div class="summary-item">
            @if (State.DependenciesTotal == 0)
            {
                <i class="bi bi-dash-circle summary-icon text-neutral"></i>
                <span>No dependencies to configure</span>
            }
            else if (State.DependenciesFound == State.DependenciesTotal)
            {
                <i class="bi bi-check-circle-fill text-ok summary-icon"></i>
                <span>All @State.DependenciesTotal dependencies found</span>
            }
            else
            {
                <i class="bi bi-exclamation-triangle-fill text-warning summary-icon"></i>
                <span>@State.DependenciesFound of @State.DependenciesTotal dependencies found — <a href="/settings/dependencies">check Settings</a></span>
            }
        </div>

    </div>

    <p class="done-footer">You can re-run this wizard anytime from Settings > General.</p>
</div>

@code {
    [Parameter] public SetupWizard.WizardState State { get; set; } = default!;
}

<style>
    .done-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        max-width: 500px;
        margin: 0 auto;
    }

    .done-icon {
        font-size: 64px;
        color: var(--success-color);
        margin-bottom: 1rem;
    }

    .done-heading {
        color: var(--text-primary);
        margin-bottom: 1rem;
    }

    .done-description {
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
    }

    .summary-list {
        width: 100%;
        text-align: left;
        margin-bottom: 1.5rem;
    }

    .summary-item {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 12px;
        padding: 0.75rem 0;
        border-bottom: 1px solid var(--border-color);
        color: var(--text-secondary);
    }

    .summary-item:last-child {
        border-bottom: none;
    }

    .summary-icon {
        font-size: 1.2rem;
        flex-shrink: 0;
    }

    .text-ok {
        color: var(--success-color);
    }

    .text-warning {
        color: var(--warning-color);
    }

    .text-neutral {
        color: var(--text-muted);
    }

    .done-footer {
        color: var(--text-muted);
        font-size: 0.875rem;
        margin-top: 0.5rem;
    }
</style>
