# .NET build output
bin/
obj/
publish/

# IDE
.vs/
.vscode/
*.user
*.suo

# OS
Thumbs.db
Desktop.ini
.DS_Store

# SQLite runtime databases (not the EF migrations)
*.db
*.db-shm
*.db-wal

# Data Protection keys (machine-specific)
keys/

# Build logs
build.log

# Root-level binaries (existing tools — not part of the .NET project)
/*.exe
/*.dll
/*.bat
/*.vbs
/*.ico
/*.png
/scrcpy-server
/source.properties
/mke2fs.conf
/*.lnk

# PowerShell scripts (legacy, kept for reference but not part of new app)
/*.ps1

# Jellyfin backup directory
/jellyfin-db-bkup-and-logs/

# Superpowers brainstorm artifacts
.superpowers/

# Superpowers worktrees (isolated implementation workspaces)
.worktrees/

# ws-scrcpy-web (separate repo, linked at runtime)
ws-scrcpy-web/

# Android platform-tools notices (bundled binary licenses)
NOTICE.txt

# Managed dependency binaries (downloaded at runtime, not tracked in git)
src/ControlMenu/dependencies/platform-tools/*
src/ControlMenu/dependencies/scrcpy/*
src/ControlMenu/dependencies/node/*
src/ControlMenu/dependencies/sqlite3/*
src/ControlMenu/dependencies/go2rtc/*
!src/ControlMenu/dependencies/*/.gitkeep

# Runtime-generated go2rtc config (rebuilt on startup from cameras table)
src/ControlMenu/go2rtc.yaml

# Temp files from icon conversion
src/ControlMenu/wwwroot/temp/

# Claude Code session artifacts (user-local)
.claude/

# Keep these directories
!src/
!tests/
!docs/
